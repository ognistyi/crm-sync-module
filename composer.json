{
    "name": "ognistyi/crm-sync-module",
    "description": "Universal handler-based sync module for Yii2 — bidirectional RabbitMQ sync with declarative entity handlers, ACK confirmation, batch initial sync.",
    "type": "yii2-extension",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.0",
        "yiisoft/yii2": "~2.0.40",
        "php-amqplib/php-amqplib": "^3.5",
        "ramsey/uuid": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yiisoft/yii2-coding-standards": "~2.0"
    },
    "autoload": {
        "psr-4": {
            "ognistyi\\sync\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ognistyi\\sync\\tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ]
}
